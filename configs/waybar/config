{
  "layer": "top",
  "position": "top",
  "height": 30,
  "spacing": 10,
  "modules-left": ["hyprland/workspaces"],
  "modules-center": [],
  "modules-right": ["cpu", "memory", "network", "pulseaudio", "clock"],
  "hyprland/workspaces": {
    "all-outputs": true,
    "disable-scroll": true,
    "format": "{name}"
  },
  "cpu": {
    "interval": 2,
    "format": "CPU {usage}%",
    "tooltip": false
  },
  "memory": {
    "interval": 2,
    "format": "RAM {}%",
    "tooltip": false
  },
  "network": {
    "format-wifi": "NET {signalStrength}%",
    "format-ethernet": "NET ETH",
    "format-disconnected": "NET OFF",
    "tooltip": false
  },
  "pulseaudio": {
    "format": "VOL {volume}%",
    "format-muted": "VOL MUTE",
    "scroll-step": 5,
    "tooltip": false
  },
  "clock": {
    "interval": 60,
    "format": "{:%Y-%m-%d %H:%M}",
    "tooltip": false
  }
}
